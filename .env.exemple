# ========================================
# ANTHROPIC AI CONFIGURATION (PRIMARY)
# ========================================
# Get your key at: https://console.anthropic.com/
# Using Claude 3.5 Sonnet for superior reasoning
ANTHROPIC_API_KEY=

# ========================================
# BACKUP AI PROVIDERS (FALLBACK ONLY)
# ========================================
# Gemini API Key (legacy - can be removed)
GEMINI_API_KEY=

# OpenAI API Key (fallback option)
OPENAI_API_KEY=

# ========================================
# EMAIL CONFIGURATION
# ========================================
# SMTP Server details for sending lead notifications
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
CONTACT_EMAIL=

# ========================================
# AWS S3 CONFIGURATION (SERVER-SIDE ONLY)
# ========================================
# Used only by /api/upload and /api/delete-file. Do NOT prefix with NEXT_PUBLIC_.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# ========================================
# FIREBASE CLIENT CONFIGURATION
# ========================================
# For authentication and database (browser-safe public keys)
NEXT_PUBLIC_APIKEY=
NEXT_PUBLIC_AUTHDOMAIN=
NEXT_PUBLIC_PROJECTID=
NEXT_PUBLIC_STORAGEBUCKET=
NEXT_PUBLIC_MESSAGINGSENDERID=
NEXT_PUBLIC_APPID=

# ========================================
# FIREBASE ADMIN (SERVER-SIDE) — required for upload/delete API auth
# ========================================
# Service account credentials. Get from Firebase Console > Project Settings > Service Accounts.
# IMPORTANT: keep PRIVATE_KEY on a single line with literal \n for newlines, wrapped in quotes.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ========================================
# ADMIN SEED SCRIPT (scripts/seed-project.mjs)
# ========================================
# Credentials d'un compte Firestore autorisé en écriture sur 'projects'
FIREBASE_ADMIN_EMAIL=
FIREBASE_ADMIN_PASSWORD=
